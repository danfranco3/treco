# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-32-byte-hex-string

# Database — SQLite default, switch to Postgres for production
DATABASE_URL=sqlite+aiosqlite:///./treco.db
DATABASE_MODE=sqlite

# For Postgres (docker-compose includes postgres service):
# DATABASE_URL=postgresql+asyncpg://treco:treco@db/treco
# DATABASE_MODE=postgres

# LLM — for acceptance criteria extraction (optional)
# Without a key, criteria are parsed from markdown checkboxes in the description
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic

# CORS — add your frontend origin if not localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
